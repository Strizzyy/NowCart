# ---- LLM providers (free tier) ----
# Get a free Groq key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Get a free Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Which provider handles text reasoning: groq | gemini | mock
LLM_TEXT_PROVIDER=groq
# Which provider handles vision (image): gemini | mock
LLM_VISION_PROVIDER=gemini

# ---- DynamoDB ----
# For local dev run DynamoDB Local (docker) and point here.
# Leave DYNAMODB_ENDPOINT empty to use real AWS DynamoDB (free tier).
AWS_REGION=ap-south-1
DYNAMODB_ENDPOINT=http://localhost:8001
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Set to "memory" to skip DynamoDB entirely and use the in-process store
# (fastest path to a running demo). Options: dynamodb | memory
DATA_BACKEND=memory

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
# Set to "true" to use an in-process cache instead of Redis
CACHE_IN_MEMORY=true

# ---- App ----
APP_ENV=dev
CONFIDENCE_THRESHOLD=0.7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
